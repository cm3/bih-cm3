@unpublished{kameda2026-bibliographic-information-hub,
  title        = {Bibliographic Information Hub: 分散した書誌情報を接続し発見・活用を支える軽量基盤の提案},
  author       = {亀田, 尭宙 and 駒居, 幸},
  year         = {2026},
  date         = {2026-03-19},
  langid       = {japanese},
  abstract     = {本稿は、分散する既存の書誌識別子や書誌情報の公開・共有サービスを接続する軽量な書誌集約基盤として、Bibliographic Information Hub（BIH）を提案する。文献調査・分析を主な手法とする人文学の分野においては、その分野で活用可能な「文献リスト」を公開し、共有することが研究活動の発展に貢献する。研究機関や大学図書館が作成する研究支援のための文献リスト、個別論文の参考文献リスト等がその事例であり、こうした文献リストは研究者が当該分野の研究を一覧し、必要な文献情報を活用することに寄与する。このような文献リストを研究者や研究機関が他の研究者の利用に供しようとする際、文献管理ツールが提供する書誌情報の公開機能は有用である。人間がブラウズでき、他者が文献データを取り込める点で実践的だからである。しかし、文献リストに掲載された各文献のデータには、必ずしもDOIのように標準化された永続的な識別子が対応しているとは限らず、同じ文献データを指す情報が散在することが避けられない。そのため、文献管理ツールを用いて文献リストを公開するだけでは、引用情報の提供や関連資料の接続が困難な状況が生まれる。そこで、本稿では、書誌レコード単位の識別子ではなく、資料単位での情報集約を可能にし、文献ごとに複数の書誌レコード・識別子・関連情報源を束ねる BIH アイテムのデータモデルによって、識別子の散在の解決や文献管理ソフトウェアとの連携を可能にする仕組みを提案する。},
  ids          = {ch141-bih2026},
}

